{
  "name": "mcp-stata",
  "version": "2.5.1",
  "description": "mcp-stata — a research-grade Stata MCP toolkit with structured outputs, paper workflows, prompts, diagnostics, and safety guardrails for local AI agents.",
  "contextFileName": "AGENTS.md",
  "mcpServers": {
    "mcp-stata": {
      "cwd": "${extensionPath}",
      "command": "uvx",
      "args": [
        "--refresh",
        "--refresh-package",
        "mcp-stata",
        "--from",
        "mcp-stata@latest",
        "mcp-stata"
      ],
      "env": {
        "STATA_PATH": "${STATA_PATH:-}",
        "MCP_STATA_STARTUP_DO_FILE": "${MCP_STATA_STARTUP_DO_FILE:-}",
        "MCP_STATA_TEMP_DIR": "${MCP_STATA_TEMP_DIR:-}"
      }
    }
  },
  "plan": {
    "directory": ".gemini/plans"
  }
}
