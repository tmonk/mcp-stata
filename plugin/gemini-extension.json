{
  "name": "mcp-stata",
  "version": "3.0.1",
  "description": "mcp-stata - an agentic toolkit for empirical researchers. Gives AI agents native control over a local Stata installation, allowing agents to run do-files, inspect data, check stored results, and export graphs.",
  "contextFileName": "AGENTS.md",
  "mcpServers": {
    "mcp-stata": {
      "cwd": "${extensionPath}",
      "command": "uvx",
      "args": [
        "--refresh",
        "--refresh-package",
        "mcp-stata",
        "--from",
        "mcp-stata@latest",
        "mcp-stata"
      ],
      "env": {
        "STATA_PATH": "${STATA_PATH:-}",
        "MCP_STATA_STARTUP_DO_FILE": "${MCP_STATA_STARTUP_DO_FILE:-}",
        "MCP_STATA_TEMP_DIR": "${MCP_STATA_TEMP_DIR:-}"
      }
    }
  },
  "plan": {
    "directory": ".gemini/plans"
  }
}
